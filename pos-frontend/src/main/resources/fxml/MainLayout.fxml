<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="mainBorderPane" style="-fx-font-family: 'Segoe UI';" xmlns:fx="http://javafx.com/fxml" fx:controller="com.posystem.fx.controller.MainLayoutController">

    <!-- Top Navigation -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="GAYAL MOBILE SHOP - POS SYSTEM" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <!-- Left Sidebar Navigation -->
    <left>
        <VBox style="-fx-background-color: #34495e; -fx-padding: 20; -fx-spacing: 15;" prefWidth="150">
            <Label text="Navigation" style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;"/>
            
            <Button fx:id="posButton" text="POS Screen" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120;"/>
            <Button fx:id="productsButton" text="Products" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120;"/>
            <Button fx:id="categoriesButton" text="Categories" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120;"/>
            <Button fx:id="reportsButton" text="Reports" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120;"/>
            
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
        </StackPane>
    </center>

</BorderPane>

