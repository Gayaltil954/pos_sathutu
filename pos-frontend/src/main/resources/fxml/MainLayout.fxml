<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="mainBorderPane" style="-fx-font-family: 'Segoe UI';" xmlns:fx="http://javafx.com/fxml" fx:controller="com.posystem.fx.controller.MainLayoutController">

    <!-- Top Navigation -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="SATHUTU MOBILE SHOP - POS SYSTEM" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                <Label fx:id="versionLabel" text="Version: -" style="-fx-text-fill: #ecf0f1; -fx-font-size: 12;"/>
                <Button fx:id="updateButton" text="Update Available" visible="false" managed="false" onAction="#refreshUpdateStatus" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 11;"/>
            </HBox>
            <Label fx:id="dashboardLowStockAlertLabel" text="" visible="false" managed="false" style="-fx-text-fill: #f1c40f; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 6 0 0 0;"/>
        </VBox>
    </top>

    <!-- Left Sidebar Navigation -->
    <left>
        <VBox style="-fx-background-color: #34495e; -fx-padding: 20; -fx-spacing: 15;" prefWidth="150">
            <Label text="Navigation" style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;"/>
            
            <Button fx:id="posButton" text="POS Screen" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120;"/>
            <Button fx:id="productsButton" text="Products" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120;"/>
            <Button fx:id="categoriesButton" text="Categories" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120;"/>
            <Button fx:id="reportsButton" text="Reports" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120;"/>
            <Button fx:id="exitButton" text="Exit System" style="-fx-padding: 12; -fx-font-size: 12; -fx-min-width: 120; -fx-background-color: #c0392b; -fx-text-fill: white;"/>
            
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
        </StackPane>
    </center>

</BorderPane>

